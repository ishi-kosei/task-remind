# PostgreSQL接続URL（Railway/RenderがDB作成後に自動で入る）
DATABASE_URL=postgresql://user:password@host:5432/dbname

# LINE Developers > Messaging API チャネルから取得
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# オプション：LINEボットに話しかけると自動登録されるので、手動設定は不要
# LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ポート（Render/Railwayが自動設定するので変更不要）
PORT=3000
